{
    "openapi": "3.0.0",
    "info": {
        "title": "Minha API Laravel 12",
        "description": "Documentação oficial das rotas da API desenvolvida em PHP 8.2.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor Local de Desenvolvimento"
        }
    ],
    "paths": {
        "/api/addresses": {
            "get": {
                "tags": [
                    "Endereços"
                ],
                "summary": "Listar endereços do usuário autenticado",
                "description": "Retorna todos os endereços pertencentes ao usuário autenticado.",
                "operationId": "33ccea30443418dbab9242aa67931614",
                "responses": {
                    "200": {
                        "description": "Lista de endereços retornada com sucesso"
                    },
                    "401": {
                        "description": "Usuário não autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Endereços"
                ],
                "summary": "Cadastrar endereço",
                "description": "Cria um novo endereço para o usuário autenticado.",
                "operationId": "5549e34fec9817a9794302a767fc7fde",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "address",
                                    "city",
                                    "state",
                                    "cep",
                                    "number"
                                ],
                                "properties": {
                                    "address": {
                                        "type": "string",
                                        "example": "Rua das Flores"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Lages"
                                    },
                                    "state": {
                                        "type": "string",
                                        "example": "SC"
                                    },
                                    "cep": {
                                        "type": "string",
                                        "example": "88501-000"
                                    },
                                    "number": {
                                        "type": "string",
                                        "example": "123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Endereço criado com sucesso"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/addresses/{id}": {
            "get": {
                "tags": [
                    "Endereços"
                ],
                "summary": "Busca endereço o endereço específico",
                "description": "Retorna um endereço específico do usuário autenticado.",
                "operationId": "de6419a46a2f3639437add4f3cb76e5d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do endereço",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Endereço encontrado"
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/addresses/update/{id}": {
            "put": {
                "tags": [
                    "Endereços"
                ],
                "summary": "Atualizar endereço",
                "description": "Atualiza um endereço pertencente ao usuário autenticado.",
                "operationId": "935dc7ed678b70230a1178576a7e83c9",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do endereço",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "address": {
                                        "type": "string",
                                        "example": "Rua Central"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Florianópolis"
                                    },
                                    "state": {
                                        "type": "string",
                                        "example": "SC"
                                    },
                                    "cep": {
                                        "type": "string",
                                        "example": "88000-000"
                                    },
                                    "number": {
                                        "type": "string",
                                        "example": "456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Endereço atualizado com sucesso"
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/addresses/delete/{id}": {
            "delete": {
                "tags": [
                    "Endereços"
                ],
                "summary": "Excluir endereço",
                "description": "Remove um endereço pertencente ao usuário autenticado.",
                "operationId": "6aa04a5a776ce63972de6537e5377398",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do endereço",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Endereço removido com sucesso"
                    },
                    "404": {
                        "description": "Endereço não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/register": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Registrar um novo usuário",
                "description": "Cria um novo usuário no banco de dados e inicializa um carrinho vazio para ele.",
                "operationId": "ca7c0cb6772de9bffbb8c896980cebc8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "last_name",
                                    "email",
                                    "password",
                                    "password_confirmation",
                                    "phone"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "João",
                                        "maxLength": 20
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Silva",
                                        "maxLength": 255
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "joao.silva@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "senha123",
                                        "minLength": 8
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "senha123",
                                        "minLength": 8
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "11999998888",
                                        "maxLength": 20
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário registrado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Usuário registrado com sucesso"
                                        },
                                        "user": {
                                            "type": "object",
                                            "additionalProperties": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erro de validação nos campos enviados"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Autenticar usuário",
                "description": "Verifica as credenciais do usuário e retorna um token de acesso Bearer (Sanctum).",
                "operationId": "c373bc4cffa4a56fc64e3979b8ee7b96",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "joao.silva@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "senha123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login realizado com sucesso."
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcdefghijklmnopqrstuvwxyz..."
                                        },
                                        "user": {
                                            "type": "object",
                                            "additionalProperties": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Credenciais inválidas (E-mail ou senha incorretos)"
                    },
                    "422": {
                        "description": "Erro de validação (campos obrigatórios ausentes)"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Revogar token de acesso (Logout)",
                "description": "Invalida o token atual do usuário autenticado.",
                "operationId": "f04cdebaafab9e20aa80e0c843bb17f3",
                "responses": {
                    "200": {
                        "description": "Logout realizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Logout realizado com sucesso"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Não autorizado (Token ausente ou inválido)"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Insira o token gerado no login para acessar as rotas protegidas.",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Endereços",
            "description": "Endereços"
        },
        {
            "name": "Autenticação",
            "description": "Autenticação"
        }
    ]
}